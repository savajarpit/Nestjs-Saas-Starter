# App
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# Project type
PROJECT_TYPE=multi_tenant        # multi_tenant | single_tenant | b2c
DB_DRIVER=prisma                 # prisma | mongoose

# Database — Prisma (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/saas_db

# Database — Mongoose (MongoDB)
MONGO_URI=mongodb://localhost:27017/saas_db

# JWT — CHANGE THESE IN PRODUCTION (min 32 chars)
JWT_ACCESS_SECRET=change-this-to-a-minimum-32-character-secret
JWT_REFRESH_SECRET=change-this-to-a-different-32-character-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Encryption
ENCRYPTION_KEY=change-this-to-a-minimum-32-character-key-here