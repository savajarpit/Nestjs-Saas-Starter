NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

PROJECT_TYPE=multi_tenant
DB_DRIVER=prisma

DATABASE_URL=postgresql://postgres:password@localhost:5432/saas_db_dev

JWT_ACCESS_SECRET=dev-access-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=dev-refresh-secret-minimum-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0